htmlcov/
.tosca/
.pytest_cache/
.unittest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.nox/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
doc/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   For an library, you probably want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally check in Pipfile.lock.
#   For development, they can be useful if the library has dependencies.
#   For apps, check them in.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains dependency versions.
#   It should be checked in for apps, but ignored for libraries.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains dependency versions.
# pdm.lock

# virtualenv
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local storage for mock uploads
local_storage/
backend/local_storage/
