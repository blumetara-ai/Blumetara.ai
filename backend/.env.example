# =====================================================================
# BLUMETARA V1 - ENVIRONMENT CONFIGURATION
# Copy this file to '.env' and fill in your real credentials.
# Do NOT commit the '.env' file to Git!
# =====================================================================

# App Settings
APP_NAME="Blumetara AI Backend"
API_V1_STR="/api/v1"

# MongoDB Database URI (Use local mongodb container or a remote Atlas connection string)
MONGO_URI="mongodb://localhost:27017/blumetara_db"
DATABASE_NAME="blumetara_db"

# AWS Credentials (For live S3 storage & Textract async OCR ingestion)
AWS_ACCESS_KEY_ID="your_real_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_real_aws_secret_key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="blumetara-reports"

# Gemini LLM API Config
GEMINI_API_KEY="your_real_gemini_api_key"
AI_REASONING_MODE="lite"  # Set to 'enterprise' for clinical consensus agent reasoning

# Firebase Settings (For push notifications and token verification)
FIREBASE_PROJECT_ID="your-firebase-project-id"
GOOGLE_APPLICATION_CREDENTIALS="path/to/your/firebase-service-account-key.json"
